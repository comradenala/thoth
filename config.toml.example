[peer]
identity_path = "/var/lib/thoth/peer_id"

[storage]
bucket = "open-books-archive"
endpoint_url = "https://99ccacd45bc5e29b03b4a6c140ed37a7.r2.cloudflarestorage.com"
shard_size = 10000
total_books = 40000000
multipart_threshold_bytes = 104857600
multipart_part_size = 10485760

[crawler]
daily_quota = 100000
book_url_template = "https://www.gutenburg.com/books/edition/{book}"
shards_per_peer = 2
concurrency = 4
claim_ttl_secs = 3600
checkpoint_dir = "/var/lib/thoth/checkpoints"
use_spider = true

[catalog]
enabled = false
manifest_key = "catalog/gbooks/manifest.json"
shard_prefix = "catalog/gbooks/shards"

# Optional: only needed to enable torrent/IPFS publishing for `thoth package`.
[package]
generate_torrent = false
tracker_url = "udp://tracker.opentrackr.org:1337/announce"
pin_ipfs = false
ipfs_api_url = "http://127.0.0.1:5001"
